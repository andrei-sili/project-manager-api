# Base URL of the Django REST API, including the /api prefix (no trailing slash).
# Copy this file to .env.local and adjust for your environment.
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Cloudflare Turnstile public site key (anti-bot on registration). Leave unset
# to disable the CAPTCHA. The matching secret key goes on the backend.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Sentry DSN for browser/server error monitoring. Leave unset to disable.
# NEXT_PUBLIC_SENTRY_DSN=
