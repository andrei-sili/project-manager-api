ENVIRONMENT=development
SECRET_KEY=your-secret-key-here
FRONTEND_URL=http://localhost:3000

# Hosts / origins (comma-separated) — required in production
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database (PostgreSQL) — used when ENVIRONMENT=production; SQLite is the dev default
DATABASE_NAME=your-db-name
DATABASE_USER=your-db-user
DATABASE_PASSWORD=your-db-password

# Email — console backend by default; set these for real SMTP in production
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=no-reply@yourdomain.com