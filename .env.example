ENVIRONMENT=development
SECRET_KEY=your-secret-key-here
FRONTEND_URL=http://localhost:3000

# Hosts / origins (comma-separated) — required in production
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database — set DATABASE_HOST to use PostgreSQL; otherwise SQLite (dev default)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
DATABASE_NAME=projectmanager
DATABASE_USER=projectmanager
DATABASE_PASSWORD=your-db-password

# Redis — required for WebSockets when running more than one process
# REDIS_URL=redis://localhost:6379/0

# Set to false to allow plain HTTP in production (e.g. local docker-compose)
# SECURE_SSL_REDIRECT=true

# Email — console backend by default; set these for real SMTP in production
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=no-reply@yourdomain.com